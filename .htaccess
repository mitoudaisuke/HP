RewriteEngine On
ErrorDocument 404 /404.html

# Canonical static page URLs
RedirectMatch 301 ^/nirfi/?$ /nirfi.html
RedirectMatch 301 ^/company/?$ /about.html
RedirectMatch 301 ^/contact/?$ /contact.html
RedirectMatch 301 ^/news/?$ /news.html

# Japanese aliases
RedirectMatch 301 ^/jp/nirfi/?$ /jp/nirfi.html
RedirectMatch 301 ^/jp/company/?$ /jp/about.html
RedirectMatch 301 ^/jp/contact/?$ /jp/contact.html
RedirectMatch 301 ^/jp/news/?$ /jp/news.html

# Legacy news URLs
RedirectMatch 301 ^/news-information/?$ /news.html
RedirectMatch 301 ^/news-information/.+$ /news.html
RedirectMatch 301 ^/2025/?$ /news.html
RedirectMatch 301 ^/2025/.+$ /news.html
RedirectMatch 301 ^/jp/news-information/?$ /jp/news.html
RedirectMatch 301 ^/jp/news-information/.+$ /jp/news.html
RedirectMatch 301 ^/jp/2025/?$ /jp/news.html
RedirectMatch 301 ^/jp/2025/.+$ /jp/news.html
